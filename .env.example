# =============================================================
#  Subordinates — AI Personal Assistant
# =============================================================
# Copy this file to .env and fill in your API keys.
# Each agent can use a different LLM provider.
# =============================================================

# --- OpenAI (default) -----------------------------------------
OPENAI_API_KEY=sk-...

# --- Anthropic (optional) -------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini (optional) ---------------------------------
GEMINI_API_KEY=...

# --- Default model for the Steward agent ----------------------
# Supports any model string:
#   OpenAI:   "gpt-4o", "gpt-4o-mini"
#   Anthropic: "litellm/anthropic/claude-3-5-sonnet-20240620"
#   Gemini:    "litellm/gemini/gemini-2.0-flash"
DEFAULT_MODEL=gpt-4o

# --- Database -------------------------------------------------
DATABASE_PATH=./data/subordinates.db

# --- Logging --------------------------------------------------
LOG_LEVEL=INFO
