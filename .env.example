# =============================================================
#  OpenVassal — AI Personal Assistant
# =============================================================
# Copy this file to .env and fill in your API keys.
# Each agent can use a different LLM provider.
# =============================================================

# --- OpenAI (default) -----------------------------------------
OPENAI_API_KEY=sk-...

# --- Anthropic (optional) -------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini (optional) ---------------------------------
GEMINI_API_KEY=...

# --- Custom OpenAI-compatible providers -----------------------
# Add any provider via the Setup UI, or manually with:
# CUSTOM_<NAME>_API_KEY, CUSTOM_<NAME>_BASE_URL, CUSTOM_<NAME>_MODEL
#
# Example for DeepSeek:
# CUSTOM_DEEPSEEK_API_KEY=sk-...
# CUSTOM_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# CUSTOM_DEEPSEEK_MODEL=deepseek-chat,deepseek-reasoner
#
# Example for a self-hosted Ollama:
# CUSTOM_OLLAMA_API_KEY=dummy
# CUSTOM_OLLAMA_BASE_URL=http://localhost:11434/v1
# CUSTOM_OLLAMA_MODEL=llama3

# --- Default model for the Steward agent ----------------------
# Pick a model from the Setup UI dropdown, or enter any model
# string your provider supports. Examples:
#   OpenAI:    gpt-4o, gpt-4o-mini, gpt-4.1
#   Anthropic: claude-sonnet-4-20250514, claude-3-5-haiku-20241022
#   Gemini:    gemini-2.5-flash, gemini-2.0-flash
#   Custom:    deepseek-chat, moonshot-v1-8k, llama3
DEFAULT_MODEL=gpt-4o

# --- Database -------------------------------------------------
DATABASE_PATH=./data/openvassal.db

# --- Logging --------------------------------------------------
LOG_LEVEL=INFO
