# =============================================================
#  OpenVassal — Personal Knowledge Base (CrewAI + mem0)
# =============================================================
# Copy this file to .env and fill in your API keys.
# Each agent uses its own LLM model (configured in agents.yaml).
# =============================================================

# --- OpenAI (required for mem0 default + coder agent) ---------
OPENAI_API_KEY=sk-...

# --- Anthropic (for claude_planner agent) ---------------------
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Gemini (for gemini_chat agent) --------------------
GEMINI_API_KEY=...

# --- Moonshot / Kimi (optional, for kimi_writer agent) --------
# MOONSHOT_API_KEY=sk-...

# --- Default Agent -------------------------------------------
# Which agent to use by default in the CLI (name from agents.yaml)
DEFAULT_AGENT=gemini_chat

# --- mem0 User ID --------------------------------------------
# Unique identifier for your memory profile
MEM0_USER_ID=default_user

# --- Database -------------------------------------------------
DATABASE_PATH=./data/openvassal.db

# --- Logging --------------------------------------------------
LOG_LEVEL=INFO
